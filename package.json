{
  "name": "guli-fintech-platform",
  "private": true,
  "version": "0.9.0-rc.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "data:twse": "node scripts/fetch-twse-market.mjs",
    "data:twse:stocks": "node scripts/fetch-twse-stocks.mjs",
    "data:twse:institutional": "node scripts/fetch-twse-institutional.mjs",
    "data:twse:history": "node scripts/fetch-twse-stock-history.mjs",
    "data:twse:history:watchlist": "node scripts/fetch-twse-stock-history.mjs --watchlist",
    "data:twse:history:all": "node scripts/fetch-twse-stock-history.mjs --all",
    "data:validate": "node scripts/validate-public-json.mjs",
    "stock:snapshot:generate": "node scripts/generate-stock-snapshots.mjs",
    "snapshot:generate": "node scripts/generate-market-snapshot.mjs",
    "industry:snapshot:generate": "node scripts/generate-industry-snapshot.mjs",
    "decision:generate": "node scripts/generate-decision-index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "tslib": "^2.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "^4.1.10"
  }
}
