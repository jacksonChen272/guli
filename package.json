{
  "name": "guli-fintech-platform",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "data:twse": "node scripts/fetch-twse-market.mjs",
    "data:twse:stocks": "node scripts/fetch-twse-stocks.mjs",
    "data:twse:industries": "node scripts/fetch-twse-industry-mapping.mjs",
    "data:twse:institutional": "node scripts/fetch-twse-institutional.mjs",
    "data:twse:history": "node --experimental-strip-types scripts/data/fetchTwseHistory.ts",
    "data:twse:history:watchlist": "node --experimental-strip-types scripts/data/fetchTwseHistory.ts --symbols=2330,2313,3006 --incremental --limit=3",
    "data:twse:history:all": "node --experimental-strip-types scripts/data/fetchTwseHistory.ts --limit=1082",
    "data:history:backfill": "node --experimental-strip-types scripts/data/fetchTwseHistory.ts",
    "data:history:plan": "node --experimental-strip-types scripts/data/fetchTwseHistory.ts --plan-only --limit=100 --batch-size=20 --request-delay=1200 --batch-delay=8000 --max-retries=3",
    "data:history:audit": "node --experimental-strip-types scripts/data/auditHistorySample.ts",
    "data:history:coverage": "node --experimental-strip-types scripts/data/generateHistoryProgressSummary.ts",
    "data:history:pr-summary": "node --experimental-strip-types scripts/data/generateHistoryPullRequestSummary.ts",
    "data:history:finalize": "node --experimental-strip-types scripts/data/finalizeHistoryBackfill.ts",
    "data:history:repair": "node --experimental-strip-types scripts/data/history/repairHistoryMetadata.ts",
    "data:history:validate": "node --experimental-strip-types scripts/data/validateHistory.ts",
    "data:technical:rebuild": "node scripts/generate-technical-index.mjs && node --experimental-strip-types scripts/data/buildTechnicalManifests.ts",
    "data:update-daily": "node --experimental-strip-types scripts/data/updateDaily.ts",
    "data:validate": "node scripts/validate-public-json.mjs",
    "stock:snapshot:generate": "node scripts/generate-stock-snapshots.mjs",
    "snapshot:generate": "node scripts/generate-market-snapshot.mjs",
    "industry:snapshot:generate": "node scripts/generate-industry-snapshot.mjs",
    "decision:generate": "node scripts/generate-decision-index.mjs",
    "technical:index:generate": "node scripts/generate-technical-index.mjs",
    "screener:generate": "node scripts/generate-screener-results.mjs",
    "heatmap:generate": "node scripts/generate-market-heatmap.mjs",
    "git:check": "node scripts/check-git-state.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "latest",
    "tslib": "^2.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "^4.1.10"
  }
}
